# ========== 依赖与构建产物 ==========
node_modules/
dist/
coverage/
*.tsbuildinfo

# ========== 本地配置与敏感数据 ==========
# Kiro/AWS CodeWhisperer 凭据，含 refresh token
credentials.json
credentials.json.*
*.sqlite3
*.db

# 私钥、证书（最佳实践层防御，项目本身目前不涉及）
*.pem
*.key
*.p12
*.pfx
*.crt
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*

# 本地运行时配置与统计
config.json
config.test.json
kiro_stats.json

# ========== 日志与临时 dump ==========
*.log
logs/
# 形如 2026-04-10-114101-*.txt 的调试 dump
[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]-*.txt

# ========== 环境变量 ==========
.env
.env.*
!.env.example

# ========== 编辑器与 IDE ==========
.vscode/
.vscode-server/
.idea/
*.swp
*.swo
*~
*.bak
*.backup
*.orig

# ========== 操作系统 ==========
.DS_Store
Thumbs.db

# ========== 测试产物 ==========
.vitest-cache/
test-results/
# Playwright MCP 浏览器自动化产物（页面快照 / console log）
.playwright-mcp/

# ========== 临时目录 ==========
tmp/
temp/
.tmp/

# ========== 实验数据与脚本 ==========
experiments/
