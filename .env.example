# ============================================================================
# kiro2claude 环境变量样例
# ----------------------------------------------------------------------------
# 用法：
#   cp .env.example .env
#   然后填入 KIRO2CLAUDE_API_KEY 与 KIRO2CLAUDE_SQLITE_DB_PATH，其他项按需解除注释。
#
# 项目走纯环境变量配置（没有 JSON config 文件，也不接受 CLI 参数）。
# 所有合法变量见 src/model/schemas/config-schema.ts (envSchema)。
# 注释行以下给出的值都是源码里的真实默认，解除注释即等价于写死默认值。
#
# 认证：kiro2claude 只支持 kiro-cli 的 device code authentication。先跑
#   kiro-cli login --use-device-flow
# 完成认证，然后把 KIRO2CLAUDE_SQLITE_DB_PATH 指向 kiro-cli 的本地 SQLite 数据库。
# 详见 https://kiro.dev/docs/cli/authentication/
# ============================================================================

# ---------- 必需 ----------

# 下游 Claude 客户端鉴权 key（自定义字符串，客户端请求时用它做 x-api-key）
KIRO2CLAUDE_API_KEY=sk-local-change-me

# kiro-cli 本地 SQLite 数据库路径（支持 ~/ 展开）
# kiro-cli 在不同平台的默认路径：
#   Linux : ~/.local/share/kiro-cli/data.sqlite3
#   macOS : ~/Library/Application Support/kiro-cli/data.sqlite3
# Docker 镜像已把默认值设为 /home/kiro/.local/share/kiro-cli/data.sqlite3，
# 容器里**不需要再手动设**这个变量——直接挂载命名卷即可（见下面 Docker 示例）
KIRO2CLAUDE_SQLITE_DB_PATH="~/.local/share/kiro-cli/data.sqlite3"
#KIRO2CLAUDE_SQLITE_DB_PATH="~/Library/Application Support/kiro-cli/data.sqlite3"

# ---------- 首次启动 bootstrap login（容器部署推荐）----------
# 设置 KIRO2CLAUDE_LOGIN_START_URL 后，当 KIRO2CLAUDE_SQLITE_DB_PATH 指向的 DB 不存在时，
# 启动阶段会 spawn `kiro-cli login --license pro --identity-provider <URL>
# --region <REGION> --use-device-flow`，把 device flow URL 打到容器日志，
# 用户在外部浏览器完成认证后 SQLite DB 会被写入挂载卷。
# 后续重启因为 SQLite DB 已存在会自动跳过本步骤。
# 用法示例：
#   docker run -d --name kiro2claude --env-file .env \
#     -e KIRO2CLAUDE_HOST=0.0.0.0 \
#     -e KIRO2CLAUDE_LOGIN_START_URL=https://d-xxxxxxxxxx.awsapps.com/start \
#     -e KIRO2CLAUDE_LOGIN_REGION=us-east-1 \
#     -p 8080:8080 \
#     -v kiro-home:/home/kiro/.local/share/kiro-cli \
#     kiro2claude
#   docker logs -f kiro2claude   # 看到 device flow URL，浏览器打开完成认证
#KIRO2CLAUDE_LOGIN_START_URL=
# 留空时回退到 KIRO2CLAUDE_REGION
#KIRO2CLAUDE_LOGIN_REGION=
#KIRO2CLAUDE_LOGIN_LICENSE=pro
# 整个 device flow 的超时时间（毫秒），默认 10 分钟
#KIRO2CLAUDE_LOGIN_TIMEOUT_MS=600000

# ---------- HTTP 服务 ----------

# 监听地址：本机开发用 127.0.0.1；Docker 容器里必须设 0.0.0.0 才能端口映射
KIRO2CLAUDE_HOST=127.0.0.1
KIRO2CLAUDE_PORT=8080

# ---------- AWS Region ----------

# KIRO2CLAUDE_REGION 是默认 region；AUTH/API 留空时会 fallback 到它
#KIRO2CLAUDE_REGION=us-east-1
# 留空即等于 KIRO2CLAUDE_REGION；只有需要把 Token 刷新和 API 请求走不同 region 时才设
#KIRO2CLAUDE_AUTH_REGION=
#KIRO2CLAUDE_API_REGION=

# ---------- 日志 ----------

# pino level：trace / debug / info / warn / error / fatal / silent
LOG_LEVEL=debug

# ---------- kiro-cli 仿真画像 ----------
# 画像加载优先级：KIRO2CLAUDE_CLIENT_PROFILE_PATH > fixtures/kiro-cli-profile.json
# > 内置 FALLBACK_PROFILE（kiro-cli 2.0.0 常量）

# 显式指定一个捕获好的 profile JSON，覆盖仓库自带 fixture。
# 典型用法：本地用 scripts/capture-kiro-cli.sh 抓到 /tmp/p.json 后临时验证。
#KIRO2CLAUDE_CLIENT_PROFILE_PATH=

# 启动时自动跑 scripts/capture-kiro-cli.sh 从本机 kiro-cli 抓一次最新画像，
# 写到 $TMPDIR/kiro2claude-profile.json，然后把 KIRO2CLAUDE_CLIENT_PROFILE_PATH 指向它。
# 仓库 fixture 不会被覆盖。
# 前置条件（缺一不可）：
#   1) 值为 true（接受 true/1/yes/on）
#   2) 本机有可执行的 kiro-cli（kiro-cli --version 能退出 0）
# 注意：auto-capture 会用真实 token 发一次 "ping" 请求，并临时改写
# kiro-cli 的 api.codewhisperer.service 设置 ~3 秒（结束时回滚）。
# 容器部署里开启此项需要镜像内装有 kiro-cli 二进制。
#KIRO2CLAUDE_AUTO_CAPTURE_PROFILE=false

# auto-capture / bootstrap-login 用哪个 kiro-cli 可执行文件；默认在 PATH 里找 `kiro-cli`
#KIRO2CLAUDE_CLI_BIN=kiro-cli

# ---------- 特性开关 ----------

# 是否从上游响应里抽取 <thinking> 标签作为 reasoning 内容
# 接受 true/false/1/0/yes/no/on/off
#KIRO2CLAUDE_EXTRACT_THINKING=true

# 身份覆写：默认（true）在 system prompt 末尾追加一行身份 directive，让模型自报为
# Claude / Anthropic，挡住它自报为 Amazon Q / Kiro。关闭（false）可换回更高的
# prompt cache 命中率，代价是模型在被问"你是谁"时可能暴露上游后端身份。
#KIRO2CLAUDE_IDENTITY_OVERRIDE=true

# 下游发来的 document 内容块（如 Claude Code 读 PDF 产生的 base64 PDF）的处理方式。
# Kiro 上游只有 text + images 通道、没有 document 通道，无法原样转发。
# true（默认）：把 document 块替换成一段文本占位提示，请求照常 200 成功——模型
#   由此显式得知"有个读不了的文档"，可自行抽取文本后重发，而不是被静默丢弃后
#   凭空幻觉。false：保留旧行为，静默丢弃 document 块 + 只打 warn 日志。
#KIRO2CLAUDE_REJECT_UNSUPPORTED_DOCUMENTS=true

# 泄漏工具调用文本救援。上游偶发把模型的工具调用当**纯文本**发下来（而非结构化
# toolUseEvent），下游看到一段 <invoke name="Edit">... 标记文本，工具调用等于丢失；
# 且泄漏文本留在会话历史里会被模型模仿，同一会话内确定性复发（自我污染）。
# true（默认）：响应侧把格式完整的泄漏块就地解析回真正的 tool_use（行首 + 代码
#   围栏外 + 工具名已注册 + 语法完整，四重门防误报）；请求侧把 assistant 历史里
#   的泄漏块剥掉，已污染会话自愈。false：关闭，泄漏文本原样透传（旧行为）。
#KIRO2CLAUDE_TOOL_CALL_TEXT_RESCUE=true

# 上游偶发返回「200 OK + 零内容帧」的空流(silent failure)。pre-commit 阶段
# 检测到后,网关对同一请求最多重发这么多次来透明吸收瞬时空流(多数重试即恢复,
# 客户端不会看到 529)。默认 2;0 = 关闭重试退回纯转发;上限 5。
# 注意:这是对「零重试转发」哲学的有意例外;每次重试都会真实消耗上游 credit。
#KIRO2CLAUDE_EMPTY_STREAM_RETRIES=2

# 诊断用:设为一个目录路径后,只要某次请求最终判定为空流(无论是否发生重试、
# 含 KIRO2CLAUDE_EMPTY_STREAM_RETRIES=0 的单次空响应),就把原始 Claude 请求体追加
# 写到该目录下的 empty-requests.jsonl(每行一条 JSON),用于事后定位「确定性空流」
# 根因。默认不抓包。
# ⚠ 原始请求体含完整 system prompt / 对话历史 / 工具定义 / 用户输入,可能含 PII 或
#   密钥,且以明文落盘(无脱敏 / 轮转 / 权限收紧)。仅在受控诊断环境短期启用,用毕
#   关闭并清理。
#KIRO2CLAUDE_CAPTURE_EMPTY_DIR=/var/log/k2c-empty

# ---------- Token 计数回退（可选远程 API）----------
# 未配置 URL 时走本地近似估算；配置后可优先调用远程更准确的 tokenizer。
# 实际链路中 input_tokens 会被 Kiro 上游的 ContextUsage 事件覆盖（如果有），
# 远程 API 的准确性优势有限，大多数部署无需配置。

#KIRO2CLAUDE_COUNT_TOKENS_API_URL=
#KIRO2CLAUDE_COUNT_TOKENS_API_KEY=
# x-api-key / bearer
#KIRO2CLAUDE_COUNT_TOKENS_AUTH_TYPE=x-api-key

# ---------- metering 插件（free，默认启用）----------
# @kiro2claude/plugin-metering 随 core 镜像携带并默认启用：每次请求在 usage 里
# 注入 kiro_metering（本次消耗 credit + 套餐内/超额成本拆分）。设为 true 关闭。
# 注意：该插件内存累计，仅适用于单实例部署。
#KIRO2CLAUDE_METERING_DISABLE=false

# ---------- derived 插件（first-party，默认启用）----------
# @kiro2claude/plugin-derived 随 core 镜像携带并默认启用：把 Kiro 原始 credit
# 反演成 Anthropic 风格 input_tokens / cache_* 字段，注入 usage.kiro_derived。
# 这些 env 由插件通过 ctx.env 自读，不进 core 的 config schema 校验。

# 成本倍率:下游最终看到的 finalCostUsd = max(claudeEquivalentCostUsd × μ, credits × 0.04)
# 1.0  = Anthropic 公示价(默认)
# 0.67 = 任意请求形态数学上不亏(上游 overage 边界)
# 详见 packages/plugin-derived/docs/cost-multiplier.md
#KIRO2CLAUDE_COST_MULTIPLIER=1.0

# 诊断模式:设 true 时保留标准 token 字段、改以 kiro_derived 扩展暴露反演拆分;
# 默认(未设/false)直接 override 标准 input_tokens / cache_* 字段。
#KIRO2CLAUDE_DERIVED_INCLUDE_FIELD=false

# cache 反演比例旋钮(反演分母 = 1 − 本值)。未设 = 测量默认 0.5276(重发探针实测,
# 忠实反演)。这是显式的展示/策略旋钮,不是重校准:调高 → 展示 cache_read 占比变大、
# 同时压低 claudeEquivalentCostUsd(下游按 usage 算的成本变低);只接受 [0,1),≥1 拒绝;
# 无论怎么调,聚合命中率封顶 ~87.7%(冷启动 input 恒不进分子)。
# 详见 packages/plugin-derived/docs/cost-multiplier.md §「cache 比例旋钮」。
#KIRO2CLAUDE_CACHE_READ_RATIO=0.5276
