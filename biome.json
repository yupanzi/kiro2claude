{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "files": {
    "includes": [
      "packages/*/src/**/*.ts",
      "packages/*/test/**/*.ts",
      "packages/examples/*/src/**/*.ts",
      "enterprise/**/*.ts",
      "enterprise/**/*.mjs",
      "*.ts",
      "*.json",
      "!dist",
      "!**/dist",
      "!node_modules",
      "!**/node_modules",
      "!**/cdk.out",
      "!data",
      "!**/*.d.ts",
      "!pnpm-lock.yaml",
      "!credentials.json",
      "!credentials.json.e2e-backup",
      "!config.json",
      "!.changeset"
    ]
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf",
    "useEditorconfig": false,
    "attributePosition": "auto"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all",
      "arrowParentheses": "always",
      "bracketSameLine": false,
      "bracketSpacing": true,
      "quoteProperties": "asNeeded"
    },
    "parser": {
      "unsafeParameterDecoratorsEnabled": false
    }
  },
  "json": {
    "formatter": {
      "enabled": true,
      "trailingCommas": "none"
    },
    "parser": {
      "allowComments": false,
      "allowTrailingCommas": false
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "useImportType": "error",
        "useExportType": "error",
        "useNodejsImportProtocol": "error",
        "useConst": "error",
        "useTemplate": "warn",
        "noParameterAssign": "off",
        "useNamingConvention": "off",
        "noNonNullAssertion": "warn",
        "useNumberNamespace": "error"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noConsole": {
          "level": "warn",
          "options": {
            "allow": ["warn", "error"]
          }
        },
        "noArrayIndexKey": "off",
        "noAssignInExpressions": "warn"
      },
      "complexity": {
        "noForEach": "off",
        "noExcessiveCognitiveComplexity": "off",
        "useLiteralKeys": "off"
      },
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error",
        "noUnusedFunctionParameters": "off",
        "noUnusedPrivateClassMembers": "warn",
        "useExhaustiveDependencies": "off"
      },
      "performance": {
        "noDelete": "warn",
        "noAccumulatingSpread": "warn"
      },
      "security": {
        "noDangerouslySetInnerHtml": "error"
      },
      "nursery": {
        "noFloatingPromises": "off"
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/test/**/*.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off",
            "noConsole": "off"
          },
          "style": {
            "noNonNullAssertion": "off"
          },
          "correctness": {
            "noUnusedFunctionParameters": "off"
          }
        }
      }
    },
    {
      "includes": ["enterprise/**/*.ts"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "@kiro2claude/core": "enterprise/ packages must use @kiro2claude/plugin-api contract, not import core internals",
                  "../../packages/core": "enterprise/ packages must not reach into core source — use @kiro2claude/plugin-api",
                  "../../packages/core/src": "enterprise/ packages must not reach into core source — use @kiro2claude/plugin-api"
                }
              }
            }
          }
        }
      }
    },
    {
      "includes": ["enterprise/**/*.mjs"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    }
  ]
}
